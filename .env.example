# Google Sheets Integration
# Get from Google Cloud Console → Service Accounts → Generate New Private Key (JSON)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Firebase Admin SDK (for sending push notifications from server)
# Get from Firebase Console → Project Settings → Service Accounts
# → Generate New Private Key → download JSON
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

# Admin FCM token — get this by visiting your deployed site with ?admin=1
# Click "Enable Now" button that appears at the top → allow notifications
# → copy the long token shown → add it here
ADMIN_FCM_TOKEN=your_admin_fcm_token_here

# Gmail for sending email verification codes
# Follow the Gmail setup instructions below
GMAIL_USER=your.clinic.email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
