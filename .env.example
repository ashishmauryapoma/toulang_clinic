# ── Google Sheets ────────────────────────────────────────────────────
# The email of your Google Service Account (from Google Cloud Console)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# The private key from your service account JSON (keep the \n characters)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# The ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# ── Twilio WhatsApp ───────────────────────────────────────────────────
# From https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Twilio Verify Service SID (for OTP) — create at console.twilio.com/verify
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio sandbox number (WhatsApp): +14155238886 (sandbox) or your approved number
TWILIO_WHATSAPP_FROM=+14155238886

# Admin's WhatsApp number (with country code, no spaces)
ADMIN_WHATSAPP_NUMBER=+601234567890
